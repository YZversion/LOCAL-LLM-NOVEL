# ── 小说素材与版权内容（绝不入 git）─────────────────────────────────────────
data/raw/*
data/raw_data/*
data/processed/*
data/story_bible/*
data/*.json
data/*.txt
data/*.epub
data/*.pdf
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/story_bible/.gitkeep

# ── 模型权重 ─────────────────────────────────────────────────────────────────
models/*
!models/.gitkeep

# ── 生成草稿 ─────────────────────────────────────────────────────────────────
outputs/*
!outputs/.gitkeep

# ── 密钥 ─────────────────────────────────────────────────────────────────────
.env

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
